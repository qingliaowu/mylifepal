{
  "manifest_version": 3,
  "name": "MyLifePal",
  "short_name": "MyLifePal",
  "version": "0.1.0",
  "description": "Tiny habits, Tomato Timer, mood checks, rewards, reminders, and life-game progress in Chrome.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "MyLifePal",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "notifications",
    "storage"
  ]
}
